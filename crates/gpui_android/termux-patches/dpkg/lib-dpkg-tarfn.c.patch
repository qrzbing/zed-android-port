+/*
+ * zed_android port: when TERMUX_APP__PACKAGE_NAME is set in the environment
+ * and differs from the upstream "com.termux" baked into Termux's prebuilt
+ * .debs, rewrite tar entry paths starting with "data/data/com.termux/" to
+ * "data/data/<env>/" at extract time. Lets a fork install upstream Termux
+ * packages without rebuilding each one for the new prefix. No-op when the
+ * env var is unset or equals "com.termux".
+ *
+ * Variable name uses Termux's double-underscore convention, same as
+ * scripts/build-bootstraps.sh:246 and scripts/build/termux_download_deb_pac.sh
+ * already use for this concept.
+ *
+ * Three lead forms accepted (file paths inside data.tar are typically
+ * relative, while symlink targets are absolute):
+ *   - "data/data/com.termux/..."
+ *   - "./data/data/com.termux/..."
+ *   - "/data/data/com.termux/..."
+ */
+static void
+tarfn_translate_termux_path(char **name_ptr)
+{
+	static char *target;
+	static int initialized;
+	static const char needle[] = "data/data/com.termux/";
+	const size_t needle_len = sizeof(needle) - 1;
+	const char *name;
+	const char *prefix;
+	size_t lead;
+	size_t target_len;
+	size_t rest_len;
+	size_t new_len;
+	char *new_name;
+	char *out;
+
+	if (!initialized) {
+		const char *env = getenv("TERMUX_APP__PACKAGE_NAME");
+		if (env != NULL && env[0] != '\0' &&
+		    strcmp(env, "com.termux") != 0)
+			target = m_strdup(env);
+		initialized = 1;
+	}
+	if (target == NULL || name_ptr == NULL || *name_ptr == NULL)
+		return;
+
+	name = *name_ptr;
+	prefix = name;
+	lead = 0;
+	if (prefix[0] == '.' && prefix[1] == '/') {
+		prefix += 2;
+		lead = 2;
+	} else if (prefix[0] == '/') {
+		prefix += 1;
+		lead = 1;
+	}
+	if (strncmp(prefix, needle, needle_len) != 0)
+		return;
+
+	target_len = strlen(target);
+	rest_len = strlen(prefix + needle_len);
+	new_len = lead + 10 /* "data/data/" */ + target_len + 1 + rest_len + 1;
+	new_name = m_malloc(new_len);
+
+	out = new_name;
+	if (lead > 0) {
+		memcpy(out, name, lead);
+		out += lead;
+	}
+	memcpy(out, "data/data/", 10);
+	out += 10;
+	memcpy(out, target, target_len);
+	out += target_len;
+	*out++ = '/';
+	memcpy(out, prefix + needle_len, rest_len);
+	out[rest_len] = '\0';
+
+	free(*name_ptr);
+	*name_ptr = new_name;
+}
+
