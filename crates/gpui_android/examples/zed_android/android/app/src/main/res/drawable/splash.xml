<?xml version="1.0" encoding="utf-8"?>
<!-- MainActivity's windowBackground. Shown between SplashActivity
     finishing and gpui drawing its first wgpu frame — a brand-
     consistent bridge so the user doesn't see a flash of system grey
     during MainActivity init. Static icon (no AVD here) because
     Android does NOT start `Animatable.start()` on a drawable when
     it's mounted as a window background; the animated version lives
     in `splash_icon_animated.xml` and only renders inside the
     SplashActivity ImageView where the View hierarchy can start the
     animators. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/zdroid_bg" />
        </shape>
    </item>
    <item
        android:gravity="center"
        android:width="200dp"
        android:height="200dp"
        android:drawable="@drawable/splash_icon_vector" />
</layer-list>
