<?xml version="1.0" encoding="utf-8"?>
<!-- Paths the in-app updater's FileProvider is allowed to share with
     Android's package installer via content:// URIs. We download the
     APK into `getCacheDir()` to avoid bloating the app's persistent
     storage; the cache dir is the only path the FileProvider exposes. -->
<paths>
    <cache-path
        name="updater_cache"
        path="updater/" />
</paths>
