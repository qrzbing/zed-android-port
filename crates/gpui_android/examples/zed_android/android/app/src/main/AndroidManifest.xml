<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-feature android:name="android.hardware.vulkan.version" android:required="false"/>

    <!--
      READ_EXTERNAL_STORAGE + WRITE_EXTERNAL_STORAGE are the legacy storage
      grants. They're still real permissions (dangerous, runtime-prompted)
      at targetSdk=28; the Settings dialog or our requestStoragePermissions()
      JNI call gates them. MANAGE_EXTERNAL_STORAGE was dropped — that's an
      API 30+ scoped-storage escape hatch that has no effect at targetSdk=28.
      `requestLegacyExternalStorage` was also dropped — it's an API 29 opt-in
      flag that's a no-op for us.
    -->
    <!-- Required for any HTTP/HTTPS — Zed's HTTP client, plus all Termux
         subprocesses (apt, pkg, curl, git, npm, etc.). Implicit pre-API 23,
         explicit after. -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
    <!-- Required for the in-app updater to hand the downloaded APK to
         Android's package installer via ACTION_VIEW. The user still has
         to grant "Install unknown apps" for this package in system
         settings the first time; we just need the manifest permission
         to be allowed to invoke the installer at all. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES"/>

    <application
        android:name=".ZedApplication"
        android:label="Zdroid"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.Zdroid.Splash"
        android:hasCode="true"
        android:appCategory="productivity"
        android:resizeableActivity="true">

        <!--
          Exhaustive configChanges: in freeform / desktop windowing mode every
          drag-resize fires a config change, which by default destroys+recreates
          the Activity (breaking our gpui Window mid-resize). Declaring every
          relevant config tells the OS to deliver onConfigurationChanged()
          instead. density+colorMode handle cross-display moves; fontScale +
          fontWeightAdjustment handle accessibility setting changes;
          layoutDirection handles RTL toggle. Verbose but cheap.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Zdroid.Splash"
            android:windowLayoutInDisplayCutoutMode="always"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|density|keyboard|keyboardHidden|navigation|uiMode|colorMode|fontScale|fontWeightAdjustment|layoutDirection|locale|mcc|mnc|touchscreen"
            android:windowSoftInputMode="adjustResize|stateAlwaysHidden">
            <meta-data
                android:name="android.app.lib_name"
                android:value="zed_android"/>
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!--
          Each cx.open_window beyond the primary spawns one of these.
          documentLaunchMode="always" implies FLAG_ACTIVITY_NEW_DOCUMENT |
          FLAG_ACTIVITY_MULTIPLE_TASK, so each open is a fresh task with its
          own Recents card and (in freeform mode) its own OS-chromed window.
          taskAffinity differentiates from MainActivity's task. exported=false
          because only our own Rust code launches it (via JNI Intent).
        -->
        <activity
            android:name=".ExtraWindowActivity"
            android:exported="false"
            android:resizeableActivity="true"
            android:documentLaunchMode="always"
            android:taskAffinity="com.zdroid.extra"
            android:windowLayoutInDisplayCutoutMode="always"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|density|keyboard|keyboardHidden|navigation|uiMode|colorMode|fontScale|fontWeightAdjustment|layoutDirection|locale|mcc|mnc|touchscreen"
            android:windowSoftInputMode="adjustResize|stateAlwaysHidden"/>

        <!--
          Exposes Zed's home dir as a SAF root so other apps can browse
          / share files from `~` via the system DocumentsUI picker. Same
          pattern Termux uses. `android.permission.MANAGE_DOCUMENTS` is
          system-only — only the system's DocumentsUI can talk to us
          directly; user-level apps reach our root by selecting it in the
          picker. `grantUriPermissions=true` lets the picker hand a
          time-limited URI grant to whatever app the user picks the file
          for.
        -->
        <provider
            android:name=".ZedDocumentsProvider"
            android:authorities="com.zdroid.documents"
            android:exported="true"
            android:grantUriPermissions="true"
            android:permission="android.permission.MANAGE_DOCUMENTS">
            <intent-filter>
                <action android:name="android.content.action.DOCUMENTS_PROVIDER"/>
            </intent-filter>
        </provider>

        <!-- FileProvider that whitelists the cache dir so the in-app
             updater can hand a content:// URI for the downloaded APK
             to Android's package installer via ACTION_VIEW. The
             installer can't read app-private file:// paths directly,
             but FileProvider mediates the grant. Authority namespaced
             under .updater so it doesn't collide with the
             DocumentsProvider above. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.zdroid.updater.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/updater_file_paths"/>
        </provider>
    </application>
</manifest>
