<?xml version="1.0" encoding="utf-8"?>
<!-- Animated splash icon. Same glyph as the launcher icon but with
     stroke alphas and widths beefed up for legibility at splash
     render size — Android 12+'s SplashScreen renders the icon at
     80-160dp inside a 288dp canvas, which would wash out the
     launcher icon's subtle 12-20% alpha rings. Here the rings are
     bolder so the brand reads from across a room, and the orb +
     halo are sized up so the breathing animation is obvious.
     Pivot at visual center (54, 54).

     Group ownership:
       - outer_rings  -> slow clockwise rotation
       - mid_ring     -> slow counter-clockwise rotation
       - inner_halo   -> alpha breathing
       - orb_group    -> scale pulse + specular ride-along -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:name="outer_rings"
        android:pivotX="54"
        android:pivotY="54">
        <!-- Outermost wavy ring — boosted from 0.12 to 0.45 alpha
             and from 1.5 to 3.0 width so the "ripple" reads at
             splash render size. -->
        <path
            android:strokeColor="#7AA2F7"
            android:strokeAlpha="0.45"
            android:strokeWidth="3.0"
            android:strokeLineJoin="round"
            android:pathData="M 99.0,54.0
                C 98.5,60.5 96.8,66.7 94.3,72.2
                C 92.6,78.0 88.7,82.8 84.0,86.5
                C 79.5,89.5 74.4,90.8 69.0,93.0
                C 63.0,94.5 56.7,93.8 50.5,93.0
                C 44.5,91.5 39.0,88.7 34.0,84.5
                C 29.5,80.5 26.5,75.4 23.5,70.0
                C 20.5,64.0 18.0,57.5 17.0,51.0
                C 16.5,44.5 18.7,38.3 21.5,32.5
                C 24.7,27.5 28.2,22.8 33.0,19.5
                C 38.0,16.5 43.7,15.5 49.5,14.5
                C 56.0,14.0 62.5,15.0 68.5,17.5
                C 74.0,19.5 78.7,23.5 83.0,27.5
                C 87.0,31.5 90.5,36.0 93.0,41.0
                C 95.5,46.5 98.5,49.5 99.0,54.0 Z" />
        <!-- Outer ring — boosted alpha 0.20 → 0.55, width 1.5 → 3.0. -->
        <path
            android:strokeColor="#7AA2F7"
            android:strokeAlpha="0.55"
            android:strokeWidth="3.0"
            android:pathData="M 14,54 A 40,40 0 1 1 94,54 A 40,40 0 1 1 14,54 Z" />
    </group>

    <group
        android:name="mid_ring"
        android:pivotX="54"
        android:pivotY="54">
        <!-- Mid ring — alpha 0.35 → 0.70, width 2 → 3.5. -->
        <path
            android:strokeColor="#7AA2F7"
            android:strokeAlpha="0.70"
            android:strokeWidth="3.5"
            android:pathData="M 22,54 A 32,32 0 1 1 86,54 A 32,32 0 1 1 22,54 Z" />
        <!-- Inner wavy ring — alpha 0.55 → 0.85, width 2.5 → 4.0. -->
        <path
            android:strokeColor="#7AA2F7"
            android:strokeAlpha="0.85"
            android:strokeWidth="4.0"
            android:strokeLineJoin="round"
            android:pathData="M 78.0,54.0
                C 78.0,59.0 76.8,64.0 74.0,68.5
                C 71.5,72.5 67.5,75.5 63.0,77.5
                C 58.5,79.0 53.5,80.0 48.5,79.0
                C 44.0,78.0 40.0,75.5 36.5,72.5
                C 33.0,69.0 30.5,64.5 30.0,59.5
                C 29.5,54.5 30.5,49.5 32.5,45.0
                C 35.0,40.5 39.0,37.0 43.5,35.0
                C 48.0,33.5 53.0,32.5 58.0,33.5
                C 62.5,34.5 66.5,37.0 70.0,40.0
                C 73.5,43.5 76.0,48.0 77.5,52.0
                C 78.0,53.0 78.0,53.5 78.0,54.0 Z" />
    </group>

    <group
        android:name="inner_halo"
        android:pivotX="54"
        android:pivotY="54">
        <!-- Halo — width 3 → 4.5, fully opaque. -->
        <path
            android:strokeColor="#A892FF"
            android:strokeAlpha="1.0"
            android:strokeWidth="4.5"
            android:pathData="M 38,54 A 16,16 0 1 1 70,54 A 16,16 0 1 1 38,54 Z" />
    </group>

    <group
        android:name="orb_group"
        android:pivotX="54"
        android:pivotY="54">
        <!-- Orb fill — full alpha, brighter accent. -->
        <path
            android:fillColor="#C8B4FF"
            android:pathData="M 45,54 A 9,9 0 1 1 63,54 A 9,9 0 1 1 45,54 Z" />
        <!-- Specular highlight — bumped 0.55 → 0.85 for splash
             legibility; the orb is the brand anchor at the icon's
             center, this lights it up properly. -->
        <path
            android:fillColor="#FFFFFF"
            android:fillAlpha="0.85"
            android:pathData="M 49,50 A 3,3 0 1 1 55,50 A 3,3 0 1 1 49,50 Z" />
    </group>
</vector>
