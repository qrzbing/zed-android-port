#!/data/data/com.zdroid/files/usr/bin/bash
# zd-runtime-sync — Populate $PREFIX/zd-runtime/ with one symlink per
# binary in the rootfs's PATH directories, all pointing at zd-exec.
#
# After running, $PREFIX/zd-runtime/git, $PREFIX/zd-runtime/node,
# $PREFIX/zd-runtime/rust-analyzer etc. all exist as symlinks to
# $PREFIX/bin/zd-exec. When Zed has $PREFIX/zd-runtime/ on PATH (ahead
# of $PREFIX/bin/), every Command::new resolves naturally through the
# wrapper and into the rootfs.
#
# Idempotent. Run on:
#   - first boot (orchestrated by the app)
#   - apt install / apt remove inside the rootfs (via dpkg post-invoke)
#   - manually, via a Zdroid command-palette action
#
# Walking the chroot's PATH dirs needs read access to those paths from
# the host side. NetHunter's /data/local/nhsystem is mode 700 / owned
# by root, so this script needs to run as root. It re-execs itself
# through su when not.

set -eu

# Same PATH-pinning logic as zd-exec: exclude $PREFIX/zd-runtime/ to
# prevent any external (find, ln, mkdir, ls, wc, tr) from PATH-resolving
# back to the wrapper symlinks and recursing.
export PATH=/data/data/com.zdroid/files/usr/bin:/system/bin:/system/xbin

PREFIX=/data/data/com.zdroid/files/usr
ZD_RUNTIME_DIR="$PREFIX/zd-runtime"
ZD_EXEC="$PREFIX/bin/zd-exec"
CONF="$PREFIX/etc/zd-runtime.conf"

# Defaults (mirrors zd-exec).
RUNTIME_TYPE=chroot
RUNTIME_ROOT=/data/local/nhsystem/kali-arm64
RUNTIME_SU=/product/bin/su

if [ -r "$CONF" ]; then
    # shellcheck source=/dev/null
    . "$CONF"
fi

if [ ! -x "$ZD_EXEC" ]; then
    echo "zd-runtime-sync: $ZD_EXEC missing or not executable" >&2
    exit 1
fi

# Re-exec via su if we need to read a root-only rootfs path.
# proot mode is userspace; no root needed.
if [ "$RUNTIME_TYPE" = "chroot" ] && [ "$EUID" != "0" ]; then
    exec env -u LD_PRELOAD "$RUNTIME_SU" -c "'$0' $*"
fi

mkdir -p "$ZD_RUNTIME_DIR"

# Install the dpkg Post-Invoke hook + apt config inside the rootfs.
# Idempotent: cp clobbers if mtime differs, no-op if identical.
# Source files ship alongside zd-runtime-sync at $PREFIX/share/zd-runtime/.
HOOK_SRC=/data/data/com.zdroid/files/usr/share/zd-runtime/zd-runtime-hook
APT_CFG_SRC=/data/data/com.zdroid/files/usr/share/zd-runtime/99-zd-runtime
if [ "$RUNTIME_TYPE" = "chroot" ] && [ -f "$HOOK_SRC" ] && [ -f "$APT_CFG_SRC" ]; then
    HOOK_DST="$RUNTIME_ROOT/usr/local/sbin/zd-runtime-hook"
    APT_CFG_DST="$RUNTIME_ROOT/etc/apt/apt.conf.d/99-zd-runtime"
    mkdir -p "${HOOK_DST%/*}" "${APT_CFG_DST%/*}"
    cp "$HOOK_SRC" "$HOOK_DST" 2>/dev/null && chmod 755 "$HOOK_DST"
    cp "$APT_CFG_SRC" "$APT_CFG_DST" 2>/dev/null && chmod 644 "$APT_CFG_DST"
fi

# PATH dirs we'll mirror. Includes the standard system bins AND
# user-local paths that /etc/profile/.profile typically prepend (npm
# global, pip user, cargo install, rustup, etc.). These show up when
# the rootfs's bash is invoked as a login shell — which zd-exec does
# unconditionally — so we need symlinks for the same names so Zed's
# PATH lookup (outside the chroot) can find them.
PATH_DIRS=(
    /usr/local/sbin
    /usr/local/bin
    /usr/sbin
    /usr/bin
    /sbin
    /bin
    /root/.local/bin
    /root/.cargo/bin
    /root/.npm-global/bin
    /root/go/bin
)

# Wipe and rebuild. Atomic-ish: build a staging dir, swap into place.
#
# Performance: each `ln -sfn` is fork+exec (~30ms on Android via su).
# Sequentially that's ~5 minutes for 10k binaries. We parallelize via
# `xargs -P` to keep it under a minute.
#
# The pipeline:
#   1. Walk PATH dirs, emit one binary basename per line.
#   2. xargs -P N reads basenames, forks N workers in parallel, each
#      runs `ln -sfn $ZD_EXEC $STAGING/<name>`.
#   3. Atomic-ish swap.
STAGING="${ZD_RUNTIME_DIR}.new"
rm -rf "$STAGING"
mkdir -p "$STAGING"

# Concurrency. 16 keeps the load avg manageable on tablet-class CPUs;
# higher just contends on the same bottleneck (su mediation, SELinux
# policy lookup) without speeding things up much.
JOBS=16

# Collect names. Use a tmp file so xargs gets a stable input.
NAMES_FILE=$(mktemp)
trap 'rm -f "$NAMES_FILE"' EXIT

# Names we DELIBERATELY don't wrap. These are utility commands Zed (and
# any reasonable Linux tool) invokes constantly during startup, env
# loading, prompt detection, and shell-substitution. Routing them
# through chroot+su+setsid+sudo+bash adds 50-200ms each AND queues on
# Magisk's su mediator. Zed's startup fires hundreds of these in
# sequence, which under su-queue contention turns into a fork
# avalanche that backs up the OS.
#
# All these have bionic equivalents in $PREFIX/bin/ that work fine for
# their intended use. The runtime swap is for tools that NEED glibc
# (LSPs, language compilers, claude, etc.) — not for `cat`.
#
# When a name in this list appears in the rootfs, we just don't create
# a wrapper. Zed's PATH (with $PREFIX/bin BEFORE $PREFIX/zd-runtime/)
# falls through to bionic for these.
SKIP_NAMES=" env sh bash dash ash zsh head tail cat ls cp mv rm mkdir \
rmdir touch chmod chown ln readlink stat file find xargs basename \
dirname tr cut sort uniq sed awk grep egrep fgrep wc which command \
true false test [ sleep echo printf expr id whoami pwd date hostname \
uname tee yes seq od hexdump xxd md5sum sha1sum sha256sum tar gzip \
gunzip zcat unzip cmp diff patch ps kill killall ps "
# Trailing/leading spaces matter for the substring test below.

skipped_count=0
for path_dir in "${PATH_DIRS[@]}"; do
    abs="$RUNTIME_ROOT$path_dir"
    [ -d "$abs" ] || continue
    for entry in "$abs"/*; do
        [ -e "$entry" ] || [ -L "$entry" ] || continue
        # Symlinks: keep unconditionally — `-x` follows the link, and
        # many rootfs symlinks point at chroot-only paths (e.g.,
        # /root/.local/bin/claude → /root/.local/share/claude/...).
        # The link target is meaningful only inside the chroot, so
        # `-x` returns false from outside and we'd skip a wrapper that
        # works fine post-chroot.
        # Regular files: must be executable AND not a directory.
        if [ -L "$entry" ] || { [ -f "$entry" ] && [ -x "$entry" ]; }; then
            name="${entry##*/}"
            # Skip if in the bionic-equivalent opt-out list.
            case "$SKIP_NAMES" in
                *" $name "*)
                    skipped_count=$((skipped_count + 1))
                    continue
                    ;;
            esac
            echo "$name" >> "$NAMES_FILE"
        fi
    done
done

# Dedupe names (a binary can show up in multiple PATH dirs). sort -u
# is plenty fast for ~10k lines and lets xargs work on a clean set.
sort -u "$NAMES_FILE" -o "$NAMES_FILE"
total=$(wc -l < "$NAMES_FILE" | tr -d ' ')

# xargs -n 1 to give each worker exactly one name. The trailing `_`
# is a placeholder that becomes $0 inside the sh -c body; xargs then
# appends the actual name from stdin as $1. (toybox xargs doesn't
# honor -I{} so we use this positional-arg pattern.)
xargs -P "$JOBS" -n 1 -a "$NAMES_FILE" \
    sh -c "ln -sfn \"$ZD_EXEC\" \"$STAGING/\$1\"" _

# Atomic-ish swap.
rm -rf "$ZD_RUNTIME_DIR"
mv "$STAGING" "$ZD_RUNTIME_DIR"

echo "zd-runtime-sync: $total wrappers in $ZD_RUNTIME_DIR (skipped $skipped_count bionic-equivalents)"
