#!/data/data/com.zdroid/files/usr/bin/bash
# zd-exec — Run a binary inside the configured Zdroid rootfs.
#
# Resolves its own argv[0] basename to a target binary name. Reads
# $PREFIX/etc/zd-runtime.conf for the runtime configuration. Dispatches:
#
#   chroot mode  — bind-mounts Zdroid's home into the rootfs, chroots
#                  in, exec's /usr/bin/<target>. Requires root (Magisk's
#                  su); the script re-execs itself through su when not
#                  already root.
#
#   proot mode   — builds proot args (-r rootfs -b binds) and exec's
#                  proot. No root needed. Higher syscall overhead but
#                  works on non-rooted devices.
#
# Stdio (fd 0/1/2) inherits transparently across the chain — no fd
# proxying needed.
#
# Two invocation modes:
#   1. As a symlink at $PREFIX/zd-runtime/<name>: argv[0] basename is
#      the target name. This is how Zed-spawned subprocesses land here
#      via PATH.
#   2. Direct: zd-exec <target> <args...>. For testing.
#
# Tty-aware: when stdin is a terminal we wrap the target with util-linux
# `setsid -c` (force-takeover TIOCSCTTY) so the inner process can do
# job control. For non-tty subprocess (LSPs, git, etc.) we skip setsid
# because it would interfere with the parent's pty.

set -u

# Pin PATH to safe dirs that DO NOT include $PREFIX/zd-runtime/.
#
# Critical: every wrapper symlink in $PREFIX/zd-runtime/ points back at
# this script. If our own PATH includes that dir, any external command
# we spawn (id, mkdir, head, anything) PATH-resolves to a wrapper,
# which re-enters this script, which spawns the same external again —
# fork bomb. Already lit one once; the device noticed.
#
# We need:
#   - $PREFIX/bin: bash itself, our shipped tools (printf is a bash
#     builtin so no concern, but other tools should still resolve here)
#   - /system/bin and /system/xbin: stock Android tools (id, mkdir,
#     mount, etc.) when our $PREFIX/bin doesn't have them
# We do NOT include $PREFIX/zd-runtime/.
export PATH=/data/data/com.zdroid/files/usr/bin:/system/bin:/system/xbin

CONF=/data/data/com.zdroid/files/usr/etc/zd-runtime.conf

# Defaults, used if conf is missing. Picked to match a stock NetHunter
# install on Samsung One UI 8 (Magisk root, Kali ARM64 chroot).
RUNTIME_TYPE=chroot
RUNTIME_ROOT=/data/local/nhsystem/kali-arm64
RUNTIME_HOME_BIND=/zed
RUNTIME_SU=/product/bin/su

# Source conf if readable. Format is shell-style KEY=value, no quoting.
if [ -r "$CONF" ]; then
    # shellcheck source=/dev/null
    . "$CONF"
fi

# Determine target binary.
SELF_NAME="${0##*/}"
if [ "$SELF_NAME" = "zd-exec" ] && [ "$#" -ge 1 ]; then
    TARGET="$1"
    shift
else
    TARGET="$SELF_NAME"
fi

HOST_CWD="$PWD"

# Translate host cwd into a path that exists inside the rootfs.
# /data/data and /data/user/0 are the canonical and symlinked forms of
# Zdroid's app data dir; both map to RUNTIME_HOME_BIND. NetHunter's
# bootkali_init bind-mounts /storage/emulated/0 at /sdcard inside the
# chroot, so external-storage paths map straight through.
case "$HOST_CWD" in
    /data/data/com.zdroid/files/home/*)
        ROOTFS_CWD="${RUNTIME_HOME_BIND}/${HOST_CWD#/data/data/com.zdroid/files/home/}"
        ;;
    /data/user/0/com.zdroid/files/home/*)
        ROOTFS_CWD="${RUNTIME_HOME_BIND}/${HOST_CWD#/data/user/0/com.zdroid/files/home/}"
        ;;
    /data/data/com.zdroid/files/home|/data/user/0/com.zdroid/files/home)
        ROOTFS_CWD="${RUNTIME_HOME_BIND}"
        ;;
    /storage/emulated/0/*)
        ROOTFS_CWD="/sdcard/${HOST_CWD#/storage/emulated/0/}"
        ;;
    /storage/emulated/0|/sdcard|/mnt/sdcard)
        ROOTFS_CWD="/sdcard"
        ;;
    /sdcard/*)
        ROOTFS_CWD="/sdcard/${HOST_CWD#/sdcard/}"
        ;;
    /mnt/sdcard/*)
        ROOTFS_CWD="/sdcard/${HOST_CWD#/mnt/sdcard/}"
        ;;
    *)
        ROOTFS_CWD="/root"
        ;;
esac

# Stdin a tty? Use setsid -c (force-takeover) so the target can own the
# pty and do job control. Non-tty: skip setsid entirely.
if [ -t 0 ]; then
    SETSID_PREFIX="/usr/bin/setsid -c"
else
    SETSID_PREFIX=""
fi

# Build a quoted-args string for re-exec via su -c, or for the inner
# bash -c body. printf %q is bash-specific (we are bash) and produces
# safe-to-eval output.
quoted_args=""
for a in "$@"; do
    quoted_args+=" $(printf '%q' "$a")"
done

run_chroot_root() {
    # We're already root here. Set up mounts, then chroot+exec.

    # Locate busybox_nh (NetHunter ships it; required for bind-mount in
    # the chroot's mount namespace because Android's stock /system/bin/mount
    # has a smaller flag surface).
    local BUSYBOX=""
    # `command -v` is a bash builtin (no external lookup) and outputs a
    # single match, so no `head -n1` needed.
    for cand in \
        "$(command -v busybox_nh 2>/dev/null)" \
        /system/xbin/busybox_nh \
        /system/bin/busybox_nh \
        /data/data/com.offsec.nethunter/scripts/bin/busybox_nh
    do
        if [ -n "$cand" ] && [ -x "$cand" ]; then
            BUSYBOX="$cand"
            break
        fi
    done
    if [ -z "$BUSYBOX" ]; then
        echo "zd-exec: busybox_nh not found (is NetHunter installed?)" >&2
        exit 1
    fi

    # bootkali_init is "idempotent" but each invocation forks ~10
    # grep+mount processes to verify /proc/mounts. When Zed spawns
    # subprocesses in rapid succession (the welcome screen alone fires
    # multiple wrapper calls — `head`, `readlink`, etc.), these stack
    # up and the device's load avg climbs into double digits within a
    # minute. Fast-path: if our mount marker (chroot's /sdcard, which
    # bootkali_init mounts last) is already a mountpoint, mounts are
    # all up — skip the bootkali_init dance entirely. ~1ms instead of
    # several seconds.
    #
    # The $0/readlink-based sibling sourcing inside bootkali_init means
    # we still have to invoke it as a subprocess with argv[0] set to
    # the script's full path — dot-sourcing breaks it.
    if ! "$BUSYBOX" mountpoint -q "$RUNTIME_ROOT/sdcard" 2>/dev/null; then
        /system/bin/sh -c ". /data/data/com.offsec.nethunter/scripts/bootkali_init" \
            /data/data/com.offsec.nethunter/scripts/bootkali_init \
            >/dev/null 2>&1 || true
    fi

    # Bind-mount Zdroid's home into the rootfs at RUNTIME_HOME_BIND.
    local bind_target="$RUNTIME_ROOT$RUNTIME_HOME_BIND"
    [ -d "$bind_target" ] || mkdir -p "$bind_target"
    if ! "$BUSYBOX" mountpoint -q "$bind_target" 2>/dev/null; then
        "$BUSYBOX" mount -o bind /data/data/com.zdroid/files/home "$bind_target" 2>/dev/null || true
    fi

    # Bind-mount $PREFIX/zd-runtime/ into the rootfs at /zed-runtime.
    # This lets the dpkg Post-Invoke hook (zd-runtime-hook), which runs
    # *inside* the chroot, write wrapper symlinks directly into the
    # host-side wrapper dir. Each apt install thereby auto-extends our
    # PATH wrappers without the host having to re-walk the rootfs.
    #
    # Symlink targets stored inside the chroot are byte strings like
    # /data/data/com.zdroid/files/usr/bin/zd-exec — that path doesn't
    # resolve inside the chroot but doesn't need to. It only needs to
    # resolve outside, where Zed does its PATH lookup.
    local zdr_bind="$RUNTIME_ROOT/zed-runtime"
    [ -d "$zdr_bind" ] || mkdir -p "$zdr_bind"
    if ! "$BUSYBOX" mountpoint -q "$zdr_bind" 2>/dev/null; then
        "$BUSYBOX" mount -o bind /data/data/com.zdroid/files/usr/zd-runtime "$zdr_bind" 2>/dev/null || true
    fi

    # Standard Linux PATH inside the rootfs (matches bootkali_env).
    local NH_PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

    # The inner bash -c body sets up env, cd's, and exec's the target.
    # We run the inner command via /bin/bash inside the rootfs because:
    #   - sudo's argv handling is fiddly with quoted args; bash -c with
    #     a body string is the simplest reliable form.
    #   - We need to set HOME=/root (sudo -E preserves the caller's
    #     HOME=/data/data/com.zdroid/files/home, which inside the chroot
    #     resolves to the bind-mounted /zed; ~/.bashrc would load from
    #     Zdroid's Termux home instead of /root, breaking colored
    #     prompts and ls --color aliases).
    # `-l` (login) is non-negotiable: it sources /etc/profile and
    # ~/.profile, which on Debian/Kali add user-local bin dirs like
    # ~/.local/bin and ~/.cargo/bin to PATH. Tools installed via
    # `pip --user`, `npm install -g` (when prefix is per-user),
    # `cargo install`, or rustup live there. Without -l the wrapper
    # invocation has the system default PATH and any user-local tool
    # is invisible — claude installed at /root/.local/bin/claude was
    # the symptom that surfaced this. Cost is a profile-source (~10ms)
    # per spawn; cheap relative to the chroot+su overhead, and the
    # alternative is "every user has to fix their PATH every time."
    exec "$BUSYBOX" chroot "$RUNTIME_ROOT" /usr/bin/sudo -E PATH="$NH_PATH" \
        $SETSID_PREFIX /bin/bash -lc "
            export TERM='${TERM:-xterm-256color}' COLORTERM='${COLORTERM:-truecolor}'
            export HOME=/root USER=root LOGNAME=root SHELL=/bin/bash
            # Prepend user-local bin dirs AFTER profile sourcing.
            # Kali's stock /root/.profile hardcodes PATH with a literal
            # assignment, clobbering anything we'd put in via sudo's
            # -E PATH=... or pre-bash export. So we add our additions
            # here, post-profile, where they actually stick.
            export PATH=/root/.local/bin:/root/.cargo/bin:/root/.npm-global/bin:/root/go/bin:\$PATH
            cd '$ROOTFS_CWD' 2>/dev/null || cd /root
            exec '$TARGET'$quoted_args
        "
}

dispatch_chroot() {
    # Use $EUID (bash builtin) instead of `id -u` to avoid any external
    # command spawn during the root-check.
    if [ "$EUID" = "0" ]; then
        run_chroot_root
    else
        # Re-exec ourselves through su to gain root. We lose env in
        # transit (Magisk's su -c default), so the re-execed instance
        # re-reads CONF and re-derives everything. That's fine — the
        # script is idempotent.
        #
        # The re-exec form depends on how we were invoked. If we ARE
        # zd-exec (direct call: `zd-exec foo --bar`), TARGET came from
        # $1 and $@ has the rest; we need to pass TARGET back as the
        # first positional so the re-execed instance can re-derive it.
        # If we were invoked via a wrapper symlink (PATH lookup of
        # `foo` hit $PREFIX/zd-runtime/foo → us), argv[0] basename IS
        # the target and the re-execed instance will derive it the
        # same way. Passing TARGET separately in the symlink case
        # double-applies it: argv would become [wrapper, TARGET, ...]
        # and the inner exec ends up as `exec '$TARGET' TARGET ...`,
        # which bash interprets as TARGET wanting to read a script
        # file named TARGET — error: cannot execute binary file.
        if [ "$SELF_NAME" = "zd-exec" ]; then
            exec env -u LD_PRELOAD "$RUNTIME_SU" -c \
                "ZD_EXEC_REENTERED=1 '$0'$(printf ' %q' "$TARGET")$quoted_args"
        else
            exec env -u LD_PRELOAD "$RUNTIME_SU" -c \
                "ZD_EXEC_REENTERED=1 '$0'$quoted_args"
        fi
    fi
}

dispatch_proot() {
    # No root needed. proot intercepts syscalls via ptrace and rewrites
    # paths so the target sees the rootfs as / from userspace. Costs
    # ~15-25% syscall overhead; works on non-rooted devices.
    if ! command -v proot >/dev/null 2>&1; then
        echo "zd-exec: proot not found on PATH (try 'pkg install proot' on Termux side)" >&2
        exit 1
    fi
    exec proot \
        -r "$RUNTIME_ROOT" \
        -b "/data/data/com.zdroid/files/home:$RUNTIME_HOME_BIND" \
        -b "/storage/emulated/0:/sdcard" \
        -- /bin/bash -lc "
            export TERM='${TERM:-xterm-256color}' COLORTERM='${COLORTERM:-truecolor}'
            export HOME=/root USER=root LOGNAME=root SHELL=/bin/bash
            export PATH=/root/.local/bin:/root/.cargo/bin:/root/.npm-global/bin:/root/go/bin:\$PATH
            cd '$ROOTFS_CWD' 2>/dev/null || cd /root
            exec '$TARGET'$quoted_args
        "
}

case "$RUNTIME_TYPE" in
    chroot) dispatch_chroot ;;
    proot)  dispatch_proot ;;
    *)
        echo "zd-exec: unknown RUNTIME_TYPE: $RUNTIME_TYPE" >&2
        exit 1
        ;;
esac
