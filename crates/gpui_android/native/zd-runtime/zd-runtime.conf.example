# zd-runtime.conf — runtime config read by zd-exec / zd-runtime-sync.
# Format: shell-style KEY=value, no quoting, no whitespace around `=`.
# Comments allowed (lines starting with `#`).
#
# Live path: $PREFIX/etc/zd-runtime.conf (i.e.,
# /data/data/com.zdroid/files/usr/etc/zd-runtime.conf).
# To use: copy this file to that path and edit the values.

# Runtime type: chroot or proot.
#
# chroot — native Linux chroot. Requires root via Magisk's su. Zero
#          per-syscall overhead, full kernel feature surface.
#
# proot  — userspace ptrace-based chroot equivalent. No root needed.
#          ~15-25% syscall overhead, can't do real mounts. Right pick
#          for non-rooted devices.
RUNTIME_TYPE=chroot

# Path to the rootfs root directory (host side).
# Defaults shown for known setups:
#   NetHunter (Kali ARM64):    /data/local/nhsystem/kali-arm64
#   proot-distro (Debian):     /data/data/com.termux/files/usr/var/lib/proot-distro/installed-rootfs/debian
#   manual install:            wherever you extracted the rootfs to
RUNTIME_ROOT=/data/local/nhsystem/kali-arm64

# Path inside the rootfs that should bind-mount Zdroid's home dir
# (/data/data/com.zdroid/files/home). Projects opened in Zdroid land
# under here when entering the rootfs.
RUNTIME_HOME_BIND=/zed

# Path to su binary on the host (chroot mode only). Magisk's su lives
# at different paths depending on Android vendor:
#   Samsung One UI 8 (post-Magisk):   /product/bin/su
#   Pixel / stock:                    /system/bin/su or /system/xbin/su
#   KernelSU:                         /data/adb/ksud or /system/bin/ksu
RUNTIME_SU=/product/bin/su
