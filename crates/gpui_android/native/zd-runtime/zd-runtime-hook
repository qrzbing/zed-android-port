#!/bin/sh
# zd-runtime-hook — chroot-side dpkg Post-Invoke hook.
#
# Runs inside the user's rootfs after `apt install`, `apt remove`, or
# `dpkg -i`. Walks the conventional PATH dirs for any binary that
# doesn't yet have a wrapper symlink in /zed-runtime, and creates one.
# /zed-runtime is a bind-mount of $PREFIX/zd-runtime on the host side,
# so writing a symlink here makes it instantly visible to Zed's PATH
# lookup outside the chroot.
#
# Idempotent. Runs after every dpkg op; only creates missing wrappers
# so the cost scales with what just changed, not the whole rootfs.
#
# Installed by zd-runtime-sync at /usr/local/sbin/zd-runtime-hook
# inside the rootfs, called via /etc/apt/apt.conf.d/99-zd-runtime.

set -u

# Path to zd-exec on the host. Symlinks point here as byte strings;
# they only need to resolve outside the chroot (where Zed does its
# PATH lookup), and that's where /data/data/com.zdroid/... exists.
ZD_EXEC=/data/data/com.zdroid/files/usr/bin/zd-exec
ZD_RUNTIME=/zed-runtime

# If the bind-mount isn't in place, the host hasn't entered the chroot
# yet through zd-exec — bail silently. apt won't notice.
[ -d "$ZD_RUNTIME" ] || exit 0
# Confirm it's actually bind-mounted (not just an empty dir of the same
# name). `mountpoint` would be tidy but isn't always present in a
# minimal rootfs; the readlink check is good enough.
[ -L "$ZD_RUNTIME/.zd-bind-marker" ] || mountpoint -q "$ZD_RUNTIME" 2>/dev/null || exit 0

added=0
for d in /usr/local/sbin /usr/local/bin /usr/sbin /usr/bin /sbin /bin \
         /root/.local/bin /root/.cargo/bin /root/.npm-global/bin /root/go/bin
do
    [ -d "$d" ] || continue
    for entry in "$d"/*; do
        [ -e "$entry" ] || [ -L "$entry" ] || continue
        # Symlinks unconditionally; regular files only if executable.
        if [ -L "$entry" ] || { [ -f "$entry" ] && [ -x "$entry" ]; }; then
            name="${entry##*/}"
            link="$ZD_RUNTIME/$name"
            [ -L "$link" ] && continue
            ln -sfn "$ZD_EXEC" "$link" 2>/dev/null && added=$((added + 1))
        fi
    done
done

# Quiet on no-op (most invocations); only log when we actually added.
[ "$added" -gt 0 ] && echo "zd-runtime-hook: $added new wrappers"
exit 0
